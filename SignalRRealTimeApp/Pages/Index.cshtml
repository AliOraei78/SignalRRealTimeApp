@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<h2>SignalR Chat Demo - Day 11 (Error Handling & Logging)</h2>

@if (SignInManager.IsSignedIn(User))
{
    <p>Welcome, <strong>@User.Identity?.Name</strong></p>
}

<div>
    <strong>Connection Status:</strong>
    <span id="connectionStatus" style="font-weight:bold; color:orange;">Connecting...</span>
</div>

<div>
    <input id="messageInput" placeholder="Enter your message" />
    <button onclick="sendMessage()">Send to All</button>
    <button onclick="sendAdminAnnouncement()">Admin Announcement</button>
    <button onclick="testScaling()">Test Scaling (Multiple Servers)</button>
</div>

<h3>Messages:</h3>
<ul id="messagesList"></ul>

<script src="~/js/signalr/dist/browser/signalr.js"></script>
<script>
    let connection;

    async function startConnection() {
    const status = document.getElementById("connectionStatus");

    connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .withAutomaticReconnect()
    .build();

    // Receive normal messages
    connection.on("ReceiveMessage", (user, message) =>
    addMessage(`${user}: ${message}`, "blue"));

    // Receive system messages and errors
    connection.on("ReceiveSystemMessage", (user, message) =>
    addMessage(`[${user}] ${message}`, "red"));

    // Receive progress updates
    connection.on("ReceiveProgress", (msg) =>
    addMessage(`📊 ${msg}`, "purple"));

    try {
    await connection.start();

    status.textContent = "Connected";
    status.style.color = "green";
    }
    catch (err) {
    console.error(err);

    status.textContent = "Connection Error";
    status.style.color = "red";
    }
    }

    function addMessage(text, color) {
    const li = document.createElement("li");

    li.textContent = text;
    li.style.color = color;

    document.getElementById("messagesList").appendChild(li);
    }

    async function testScaling() {
    if (connection) {
    await connection.invoke("SendMessage", "This message was sent to test scaling across multiple servers");
    }
    }

    async function sendMessage() {
    const message = document.getElementById("messageInput").value;

    if (connection) {
    try {
    await connection.invoke("SendMessage", message);
    document.getElementById("messageInput").value = "";
    }
    catch (err) {
    console.error(err);
    }
    }
    }

    async function sendAdminAnnouncement() {
    const message = document.getElementById("messageInput").value || "Important announcement";

    if (connection) {
    try {
    await connection.invoke("SendAdminAnnouncement", message);
    document.getElementById("messageInput").value = "";
    }
    catch (err) {
    console.error(err);
    }
    }
    }

    window.onload = startConnection;
</script>