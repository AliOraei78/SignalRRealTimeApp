@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<h2>SignalR Chat Demo - Day 10 (Streaming and Progress Reporting)</h2>

@if (SignInManager.IsSignedIn(User))
{
    <p>Welcome, <strong>@User.Identity?.Name</strong></p>
}

<div>
    <strong>Connection Status:</strong>
    <span id="connectionStatus" style="font-weight:bold;">Connecting...</span>
</div>

<div>
    <input id="messageInput" placeholder="Message" />
    <button onclick="sendMessage()">Send to All</button>
    <button onclick="startStreaming()">Start Streaming</button>
    <button onclick="startLongOperation()">Start Long Operation (Progress)</button>
</div>

<h3>Messages and Progress Reports:</h3>
<ul id="messagesList"></ul>

<script src="~/js/signalr/dist/browser/signalr.js"></script>
<script>
    let connection;

    async function startConnection() {
    const status = document.getElementById("connectionStatus");

    connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .withAutomaticReconnect()
    .build();

    connection.on("ReceiveMessage",
    (user, message) => addMessage(`${user}: ${message}`, "blue"));

    connection.on("ReceiveSystemMessage",
    (user, message) => addMessage(`[${user}] ${message}`, "red"));

    connection.on("ReceiveProgress",
    (progressMsg) => addMessage(`📊 ${progressMsg}`, "purple"));

    try {
    await connection.start();

    status.textContent = "Connected";
    status.style.color = "green";
    }
    catch (err) {
    console.error(err);

    status.textContent = "Error";
    status.style.color = "red";
    }
    }

    function addMessage(text, color) {
    const li = document.createElement("li");

    li.textContent = text;
    li.style.color = color;

    document.getElementById("messagesList").appendChild(li);
    }

    async function sendMessage() {
    const message = document.getElementById("messageInput").value;

    if (message && connection) {
    await connection.invoke("SendMessage", message);
    document.getElementById("messageInput").value = "";
    }
    }

    async function startStreaming() {
    if (!connection) return;

    try {
    const stream = connection.stream("StreamMessages", 10);

    stream.subscribe({
    next: (item) => addMessage(`📡 ${item}`, "orange"),
    complete: () => addMessage("✅ Streaming completed", "green"),
    error: (err) => addMessage("❌ Streaming error", "red")
    });
    }
    catch (err) {
    console.error(err);
    }
    }

    async function startLongOperation() {
    if (!connection) return;

    try {
    await connection.invoke("StartLongOperation", 10); // 10 steps
    }
    catch (err) {
    console.error(err);
    }
    }

    window.onload = startConnection;
</script>