@page
<h2>SignalR Chat Demo - Day 2 (Hub Basics)</h2>

<div>
    <input id="userInput" placeholder="Your name" value="Test User" />
    <input id="messageInput" placeholder="Type your message" />
    <button onclick="sendMessage()">Send to Everyone</button>
    <button onclick="sendToCaller()">Send Only to Me</button>
    <button onclick="sendToOthers()">Send to Others</button>
    <button onclick="sendSystemMessage()">System Message</button>
</div>

<ul id="messagesList"></ul>

<!-- SignalR JavaScript Client -->
<script src="~/js/signalr/dist/browser/signalr.js"></script>

<script>
    let connection;

    async function startConnection() {
    connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .build();

    // Receive public messages
    connection.on("ReceiveMessage", (user, message) => {
    const li = document.createElement("li");
    li.textContent = `${user}: ${message}`;
    li.style.color = "blue";
    document.getElementById("messagesList").appendChild(li);
    });

    // Receive private messages
    connection.on("ReceivePrivateMessage", (message) => {
    const li = document.createElement("li");
    li.textContent = message;
    li.style.color = "green";
    document.getElementById("messagesList").appendChild(li);
    });

    // Receive system messages
    connection.on("ReceiveSystemMessage", (user, message) => {
    const li = document.createElement("li");
    li.textContent = `[${user}] ${message}`;
    li.style.color = "red";
    document.getElementById("messagesList").appendChild(li);
    });

    try {
    await connection.start();
    console.log("SignalR connected successfully.");
    } catch (err) {
    console.error("Connection Error:", err);
    }
    }

    async function sendMessage() {
    const user = document.getElementById("userInput").value || "Anonymous";
    const message = document.getElementById("messageInput").value;

    if (message && connection) {
    await connection.invoke("SendMessage", user, message);
    document.getElementById("messageInput").value = "";
    }
    }

    async function sendToCaller() {
    const message = document.getElementById("messageInput").value;

    if (message && connection) {
    await connection.invoke("SendToCaller", message);
    document.getElementById("messageInput").value = "";
    }
    }

    async function sendToOthers() {
    const user = document.getElementById("userInput").value || "Anonymous";
    const message = document.getElementById("messageInput").value;

    if (message && connection) {
    await connection.invoke("SendToOthers", user, message);
    document.getElementById("messageInput").value = "";
    }
    }

    async function sendSystemMessage() {
    const message = document.getElementById("messageInput").value;

    if (message && connection) {
    await connection.invoke("BroadcastSystemMessage", message);
    document.getElementById("messageInput").value = "";
    }
    }

    window.onload = startConnection;
</script>