@page
<h2>SignalR Chat Demo - Day 4 (Groups)</h2>

<div>
    <input id="userInput" placeholder="Your name" value="Test User" />
    <input id="messageInput" placeholder="Type your message" />

    <button onclick="sendToAll()">Send to All</button>
    <button onclick="sendToGroup()">Send to Group</button>
</div>

<div>
    <strong>Group:</strong>
    <input id="groupInput" value="General" />
    <button onclick="joinGroup()">Join Group</button>
    <button onclick="leaveGroup()">Leave Group</button>
</div>

<div>
    <strong>Connection Status:</strong>
    <span id="connectionStatus" style="color:orange;">Connecting...</span>
</div>

<h3>Online Users:</h3>
<ul id="onlineUsersList"></ul>

<h3>Messages:</h3>
<ul id="messagesList"></ul>

<script src="~/js/signalr/dist/browser/signalr.js"></script>

<script>
    let connection;

    async function startConnection() {
    connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .build();

    connection.on("ReceiveMessage", (user, message) => {
    addMessage(`${user}: ${message}`, "blue");
    });

    connection.on("ReceiveSystemMessage", (user, message) => {
    addMessage(`[${user}] ${message}`, "red");
    });

    connection.on("UserConnected", (userName) => {
    addMessage(`✅ ${userName} joined.`, "green");
    });

    connection.on("UserDisconnected", (userName) => {
    addMessage(`❌ ${userName} left.`, "red");
    });

    connection.on("ReceiveOnlineUsers", (users) => {
    const list = document.getElementById("onlineUsersList");
    list.innerHTML = "";

    users.forEach(user => {
    const li = document.createElement("li");
    li.textContent = user;
    list.appendChild(li);
    });
    });

    try {
    await connection.start();
    document.getElementById("connectionStatus").textContent = "Connected";
    document.getElementById("connectionStatus").style.color = "green";
    } catch (err) {
    console.error(err);
    document.getElementById("connectionStatus").textContent = "Connection failed";
    document.getElementById("connectionStatus").style.color = "red";
    }
    }

    function addMessage(text, color) {
    const li = document.createElement("li");
    li.textContent = text;
    li.style.color = color;
    document.getElementById("messagesList").appendChild(li);
    }

    async function sendToAll() {
    const user = document.getElementById("userInput").value || "Anonymous";
    const message = document.getElementById("messageInput").value;

    if (message && connection) {
    await connection.invoke("SendMessage", user, message);
    document.getElementById("messageInput").value = "";
    }
    }

    async function joinGroup() {
    const group = document.getElementById("groupInput").value;

    if (group && connection) {
    await connection.invoke("JoinGroup", group);
    }
    }

    async function leaveGroup() {
    const group = document.getElementById("groupInput").value;

    if (group && connection) {
    await connection.invoke("LeaveGroup", group);
    }
    }

    async function sendToGroup() {
    const group = document.getElementById("groupInput").value;
    const message = document.getElementById("messageInput").value;

    if (message && group && connection) {
    await connection.invoke("SendToGroup", group, message);
    document.getElementById("messageInput").value = "";
    }
    }

    window.onload = startConnection;
</script>