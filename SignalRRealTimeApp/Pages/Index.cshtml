@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<h2>SignalR Chat Demo - Day 6 (Strongly Typed Hub)</h2>

@if (SignInManager.IsSignedIn(User))
{
    <p>Welcome, <strong>@User.Identity?.Name</strong></p>
}
else
{
    <p><a href="/Identity/Account/Login">Login</a> | <a href="/Identity/Account/Register">Register</a></p>
}

<div>
    <input id="messageInput" placeholder="Type your message" />
    <button onclick="sendMessage()">Send to everyone</button>
    <button onclick="sendToUser()">Send to specific user</button>
</div>

<div>
    <input id="targetUser" placeholder="Target username" />
</div>

<ul id="messagesList"></ul>

<script src="~/js/signalr/dist/browser/signalr.js"></script>
<script>
    let connection;

    async function startConnection() {
    connection = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .build();

    // Strongly typed hub methods
    connection.on("ReceiveMessage", (user, message) => {
    addMessage(`${user}: ${message}`, "blue");
    });

    connection.on("ReceivePrivateMessage", (sender, message) => {
    addMessage(`📩 from ${sender}: ${message}`, "green");
    });

    connection.on("UserConnected", (userName) => {
    addMessage(`✅ ${userName} joined`, "green");
    });

    connection.on("UserDisconnected", (userName) => {
    addMessage(`❌ ${userName} left`, "red");
    });

    try {
    await connection.start();
    console.log("Strongly typed hub connected");
    } catch (err) {
    console.error(err);
    }
    }

    async function sendMessage() {
    const message = document.getElementById("messageInput").value;
    if (message && connection) {
    await connection.invoke("SendMessage", message);
    document.getElementById("messageInput").value = "";
    }
    }

    async function sendToUser() {
    const target = document.getElementById("targetUser").value;
    const message = document.getElementById("messageInput").value;

    if (target && message && connection) {
    await connection.invoke("SendToUser", target, message);
    document.getElementById("messageInput").value = "";
    }
    }

    function addMessage(text, color) {
    const li = document.createElement("li");
    li.textContent = text;
    li.style.color = color;
    document.getElementById("messagesList").appendChild(li);
    }

    window.onload = startConnection;
</script>